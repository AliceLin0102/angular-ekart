/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "extends": "./tsconfig.json", //繼承自根目錄下的tsconfig.json，這樣可以共用一些基本的編譯設定。
  "compilerOptions": {
    "outDir": "./out-tsc/app",//指定編譯後的JavaScript檔案輸出目錄，這裡是out-tsc/app資料夾。
    "types": []//指定要包含在編譯中的類型定義檔案，這裡是空陣列，表示不包含任何額外的類型定義。
  },
  "include": [
    "src/**/*.ts" //告訴Typescript編譯器要包含哪些檔案進行編譯，這裡是所有src資料夾下的.ts檔案。
  ],
  "exclude": [
    "src/**/*.spec.ts" //告訴Typescript編譯器要排除哪些檔案，這裡是所有src資料夾下的.spec.ts檔案，這些通常是測試檔案，不需要編譯到生產環境中。
  ]
}
